{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "dockerfile"
  },
  "deploy": {
    "startCommand": "gunicorn --worker-class gevent --workers 1 --bind 0.0.0.0:$PORT --timeout 120 app:app",
    "restartPolicyMaxRetries": 5,
    "healthchecks": {
      "enabled": true,
      "cpu": 25,
      "memory": 256
    }
  },
  "variables": {
    "PORT": "5000",
    "FLASK_ENV": "production"
  }
}
