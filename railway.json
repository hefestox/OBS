{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "dockerfile"
  },
  "deploy": {
    "numReplicas": 1,
    "startCommand": "gunicorn --worker-class gevent --workers 4 --bind 0.0.0.0:$PORT --timeout 120 --access-logfile - --error-logfile - app:app",
    "restartPolicyMaxRetries": 5,
    "healthchecks": {
      "enabled": true,
      "cpu": 50,
      "memory": 512
    }
  },
  "variables": {
    "PORT": "5000",
    "FLASK_ENV": "production"
  }
}
