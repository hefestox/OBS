# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=1
PORT=5000

# Binance API
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here
BINANCE_TESTNET=true

# OpenAI API
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4

# Pump Detection
PUMP_THRESHOLD=5.0
PUMP_TIME_WINDOW=60
MIN_VOLUME=10000

# Alerts
ALERT_EMAIL=your_email@example.com
DISCORD_WEBHOOK=optional_discord_webhook_url

# Database (opcional)
DATABASE_URL=sqlite:///pumps.db

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/pumps.log
