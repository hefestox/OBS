# PUMPS - Configuração para Railway
# Copie este arquivo para .env e preencha os valores

# ==================== FLASK ====================
FLASK_ENV=production
FLASK_DEBUG=0
PORT=5000

# ==================== BINANCE API ====================
# Obtenha em: https://www.binance.com/en/account/api-management
BINANCE_API_KEY=seu_binance_api_key_aqui
BINANCE_API_SECRET=seu_binance_api_secret_aqui
BINANCE_TESTNET=false

# ==================== OPENAI API ====================
# Obtenha em: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-seu_openai_api_key_aqui
OPENAI_MODEL=gpt-3.5-turbo

# ==================== PUMP DETECTION ====================
PUMP_THRESHOLD=5.0
PUMP_TIME_WINDOW=60
MIN_VOLUME=10000

# ==================== ALERTS (OPCIONAL) ====================
ALERT_EMAIL=seu_email@example.com
DISCORD_WEBHOOK=sua_discord_webhook_url_aqui

# ==================== DATABASE ====================
DATABASE_URL=sqlite:///pumps.db

# ==================== LOGGING ====================
LOG_LEVEL=INFO
LOG_FILE=logs/pumps.log
